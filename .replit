modules = ["rust-stable", "web", "python-3.11", "bash"]
[agent]
expertMode = true
stack = "FLASK_VANILLA_JS"

[nix]
channel = "stable-25_05"
packages = ["openssl", "postgresql"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Build"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Build"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "CARGO_TARGET_DIR=target-build cargo build 2>&1"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = ".pythonlibs/bin/gunicorn --bind 0.0.0.0:5000 --reuse-port --reload app:app"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
AI_BASE_URL = "https://divine-vittoria-dzeckyete-d2996f6e.koyeb.app"
AI_MODEL = "qwen3.7-max"
AI_API_KEY = "sk-dzcxwlRKuyUUdkpnt7Xpj6rCj-00E_v9MA-yDHxjwUWNx2jC"

[deployment]
deploymentTarget = "autoscale"
run = [".pythonlibs/bin/gunicorn", "--bind", "0.0.0.0:5000", "app:app"]
